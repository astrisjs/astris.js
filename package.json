{
  "name": "astris.js",
  "version": "0.0.1",
  "description": "Build powerful applications. The star of your Discord stack.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome check --write src",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/astrisjs/astris.js.git"
  },
  "homepage": "https://github.com/astrisjs/astris.js#readme",
  "bugs": {
    "url": "https://github.com/astrisjs/astris.js/issues"
  },
  "keywords": [
    "discord",
    "discordjs",
    "framework",
    "bot",
    "typescript",
    "astris"
  ],
  "author": "AstrisJS Team",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@caeljs/logger": "^3.1.1",
    "discord.js": "^14.25.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@types/bun": "latest",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}