{
  "name": "astrisjs",
  "version": "1.1.1",
  "private": true,
  "workspaces": [
    "packages/**",
    "!packages/**/test/*",
    "apps/**"
  ],
  "packageManager": "bun@1.3.9",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "clean": "turbo run clean && rm -rf node_modules packages/*/node_modules",
    "publish-packages": "turbo run build test && changeset version && bun scripts/resolve-workspace-deps.ts && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@changesets/cli": "^2.30.0",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2"
  }
}
