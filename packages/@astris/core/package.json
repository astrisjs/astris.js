{
  "name": "@astris/core",
  "version": "0.1.0",
  "description": "Framework fullstack com SSR + SPA para Bun",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --format=esm --target=bun --minify --sourcemap=linked",
    "test": "bun test tests/",
    "lint": "biome check src tests",
    "format": "biome format src tests --write",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "bun",
    "fullstack",
    "ssr",
    "spa",
    "framework"
  ],
  "author": {
    "name": "Eric Freitas",
    "email": "contato@freitaseric.com",
    "url": "https://freitaseric.com"
  },
  "license": "MIT",
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@astris/types": "workspace:*",
    "@types/bun": "^1.1.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
