{
  "name": "@astrisjs/cli",
  "version": "1.1.2",
  "description": "The command line interface to manage AstrisJS framework",
  "type": "module",
  "bin": {
    "astris": "./dist/astris"
  },
  "scripts": {
    "build": "bun build src/index.ts --outfile=dist/astris --compile",
    "lint": "biome check src tests",
    "format": "biome format src tests --write",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "bun",
    "fullstack",
    "ssr",
    "spa",
    "framework"
  ],
  "author": {
    "name": "Eric Freitas",
    "email": "contato@freitaseric.com",
    "url": "https://freitaseric.com"
  },
  "license": "MIT",
  "dependencies": {
    "@astrisjs/core": "workspace:*",
    "@astrisjs/server": "workspace:*",
    "@astrisjs/web": "workspace:*",
    "@clack/prompts": "^1.2.0",
    "cac": "^7.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  }
}
